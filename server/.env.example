NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

DB_HOST=localhost
DB_PORT=3306
DB_NAME=buildintel
DB_USER=root
DB_PASSWORD=
DB_SYNC=true
DEMO_MODE=true

JWT_SECRET=change_this_secret
JWT_EXPIRES_IN=7d

